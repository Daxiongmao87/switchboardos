{
  "name": "switchboardos",
  "version": "0.1.0",
  "description": "Local-first desktop operations environment for managing remote computers over SSH",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "npm-run-all build:renderer build:electron electron:start",
    "start:dev": "concurrently -k -p \"{name}\" -n \"ANG,ELC\" -c \"cyan,yellow\" \"ng serve\" \"wait-on http://localhost:4200 && electron dist-electron/main.js\"",
    "build": "npm-run-all build:renderer build:electron",
    "build:renderer": "ng build --configuration production",
    "build:electron": "node scripts/build-electron.cjs",
    "electron:start": "electron dist-electron/main.js",
    "package": "npm-run-all build electron:package",
    "electron:package": "electron-builder --dir",
    "electron:build": "electron-builder",
    "test": "ng test",
    "lint": "ng lint"
  },
  "build": {
    "appId": "com.switchboardos.app",
    "productName": "SwitchboardOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/switchboardos/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/cdk": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "electron-builder": "^25.1.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.5.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^17.0.0",
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@types/electron": "^1.6.13",
    "@types/jasmine": "~5.1.0",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "esbuild": "^0.20.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.3.0",
    "wait-on": "^7.2.0"
  }
}
