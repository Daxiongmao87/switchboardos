{
  "name": "switchboardos",
  "version": "0.1.0",
  "description": "Local-first desktop operations environment for managing remote computers over SSH",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "echo 'Run npm run build then npm run electron:build'",
    "build": "ng build && echo 'Build Angular; bundle Electron main/preload next'",
    "test": "ng test",
    "lint": "eslint \"src/**/*.ts\"",
    "electron:build": "echo 'Bundle Electron main and preload with esbuild'",
    "electron:package": "electron-builder --dir",
    "electron:build:dist": "electron-builder"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "electron-builder": "^25.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "jasmine-core": "~5.4.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.6.0"
  }
}
