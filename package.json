{
  "name": "switchboardos",
  "version": "0.1.0",
  "description": "Local-first desktop operations environment for managing remote computers over SSH",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run start:ng\" \"npm run start:electron:watch\"",
    "start:ng": "ng serve",
    "start:electron:watch": "nodemon --watch dist-electron --ext js --exec \"electron .\"",
    "build": "ng build && npm run electron:build",
    "test": "ng test",
    "lint": "eslint \"src/**/*.ts\"",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:package": "electron-builder --dir",
    "electron:build:dist": "electron-builder",
    "electron": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "electron-store": "^8.1.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^19.0.0",
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/electron-store": "^1.3.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "jasmine-core": "~5.4.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.6.0"
  }
}
