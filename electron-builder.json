{
  "appId": "com.switchboardos.app",
  "productName": "SwitchboardOS",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist-electron/**/*",
    "dist/switchboardos/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist-electron/main.js"
  },
  "win": {
    "target": [
      "nsis"
    ]
  },
  "mac": {
    "target": [
      "dmg"
    ],
    "category": "public.app-category.developer-tools"
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "category": "Development"
  }
}
